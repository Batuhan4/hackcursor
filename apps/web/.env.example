# Next.js dashboard — copy to .env.local for local dev (never commit .env.local)
# Go API base URL:
# - local dev -> http://localhost:8080
# - live demo/prod -> https://your-render-service.onrender.com
# Final demo builds must set this to the live Render API; the web app no
# longer defaults silently to localhost.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Server-only Cursor SDK credentials. Never expose this as NEXT_PUBLIC_*.
CURSOR_API_KEY=
CURSOR_MODEL=composer-2
