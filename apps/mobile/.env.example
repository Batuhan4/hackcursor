# Expo mobile — copy to .env.local for local dev or configure in EAS.
# Local dev: http://localhost:8080
# Live demo/prod: https://omnisight-api-70gd.onrender.com
# Final demo builds must set this; the app marks live API as unavailable when
# it is missing instead of silently using localhost.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

# Google Maps SDK key for react-native-maps basemap tiles (Maps SDK for Android/iOS).
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional local-notification demo offer point.
# Set these to the cafe/Komagene-style point where the physical Expo test will happen.
EXPO_PUBLIC_DEMO_OFFER_NAME=Komagene-style YolDost Demo Cafe
EXPO_PUBLIC_DEMO_OFFER_PARTNER=Demo Cafe Partner
EXPO_PUBLIC_DEMO_OFFER_AREA=Gungoren demo point
EXPO_PUBLIC_DEMO_OFFER_LATITUDE=41.010259
EXPO_PUBLIC_DEMO_OFFER_LONGITUDE=28.874899
EXPO_PUBLIC_DEMO_OFFER_RADIUS_METERS=150
EXPO_PUBLIC_DEMO_OFFER_TEXT=Demo partner offer: take a short active-route break nearby. Sponsorship never changes route scores.
