# Cursor x ALT+TAB Hackathon — ortam değişkenleri şablonu
# Gerçek değerleri .env dosyasına koy (.env commit edilmez)

# Google görüntü kaynağı (en az biri gerekli)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
GOOGLE_STREET_VIEW_API_KEY=your_google_street_view_api_key

# Deploy hedefleri
RENDER_API_KEY=your_render_api_key
VERCEL_TOKEN=your_vercel_token

# Hugging Face (en az biri gerekli; model/dataset indirme)
HUGGINGFACE_API_KEY=your_huggingface_api_key
HF_TOKEN=your_huggingface_token

# Modal (yalnizca anonimlestirilmis veriyle egitim/fine-tuning)
MODAL_TOKEN_ID=your_modal_token_id
MODAL_TOKEN_SECRET=your_modal_token_secret

# Go backend (Render Postgres bağlantısı; Render PORT'u kendisi enjekte eder)
DATABASE_URL=postgres://user:password@host:5432/db
PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://web-lake-phi-31.vercel.app

# Next.js web
# Local dev: http://localhost:8080
# Live demo: https://omnisight-api-70gd.onrender.com
# Required for final demo; no implicit localhost fallback in the web client.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
CURSOR_API_KEY=your_cursor_api_key
CURSOR_MODEL=composer-2

# Expo mobil
# Local dev: http://localhost:8080
# Live demo: https://omnisight-api-70gd.onrender.com
# Required for final demo; missing value is shown as unavailable in the app.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
